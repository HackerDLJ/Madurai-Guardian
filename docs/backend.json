{
  "entities": {
    "IncidentReport": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "IncidentReport",
      "type": "object",
      "description": "Represents a citizen-submitted report of an urban cleanliness issue, augmented with AI classification and status tracking.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "description": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "photoUrls": { "type": "array", "items": { "type": "string" } },
        "submittedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Submitted", "Acknowledged", "In Progress", "Resolved"] },
        "isVerified": { "type": "boolean" },
        "pointsAwarded": { "type": "number", "description": "Points granted for this clean deed." },
        "aiSuggestedCategory": { "type": "string" },
        "aiAugmentedDescription": { "type": "string" },
        "detectedWastePlasticVolumeCubicMeters": { "type": "number" },
        "detectedWastePaperVolumeCubicMeters": { "type": "number" },
        "detectedWasteOrganicVolumeCubicMeters": { "type": "number" },
        "detectedWasteMetalVolumeCubicMeters": { "type": "number" },
        "detectedWasteEwasteVolumeCubicMeters": { "type": "number" },
        "detectedWasteHazardousVolumeCubicMeters": { "type": "number" }
      },
      "required": ["id", "userId", "description", "latitude", "longitude", "photoUrls", "submittedAt", "status", "isVerified"]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Extended user information including gamification stats.",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "points": { "type": "number", "default": 0 },
        "level": { "type": "number", "default": 1 },
        "badges": { "type": "array", "items": { "type": "string" } },
        "isShopkeeper": { "type": "boolean", "default": false },
        "heritageCredits": { "type": "number", "default": 0, "description": "Credits specifically for traders." }
      },
      "required": ["uid", "displayName", "points"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Public and private user profile data."
        }
      },
      {
        "path": "/incidentReports/{incidentReportId}",
        "definition": {
          "entityName": "IncidentReport",
          "schema": { "$ref": "#/backend/entities/IncidentReport" },
          "description": "Global collection of all citizen reports for the city map."
        }
      }
    ]
  }
}